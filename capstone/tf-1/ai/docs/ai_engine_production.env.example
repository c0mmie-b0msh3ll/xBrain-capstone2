# TF1 AI Engine production env template
# Copy this file and fill the TODO values during deployment.

# Required: production/runtime identity
APP_ENV=prod
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# Required unless CDO uses SigV4/JWT at the gateway instead.
# Store as a secret, not a ConfigMap.
SERVICE_AUTH_TOKEN=TODO_SET_IF_USING_BEARER_TOKEN

# Required: triage behavior and request guardrails
AIOPS_INVESTIGATION_MODE=auto
AIOPS_TRIAGE_DEADLINE_SECONDS=30
AIOPS_RATE_LIMIT_PER_MINUTE=60
AIOPS_MAX_REQUEST_BYTES=524288
AIOPS_MAX_CONCURRENT_TRIAGE_REQUESTS=0

# Required: AgentCore/Bedrock production path
AGENTCORE_RUNTIME_ARN=TODO_AGENTCORE_RUNTIME_ARN
ENABLE_AGENTCORE_LLM=true
ENABLE_AGENTCORE_LLM_TOOLS=true

# Optional: model/cost controls
BEDROCK_MODEL_ID=us.amazon.nova-micro-v1:0
BEDROCK_MODEL_IDS=
BEDROCK_MAX_TOKENS=700
AIOPS_AGENT_MAX_ITERATIONS=2
AIOPS_AGENT_MAX_TOOL_CALLS=5
AIOPS_ASSISTED_COMPLEXITY_THRESHOLD=3
AIOPS_AGENT_COMPLEXITY_THRESHOLD=6
AIOPS_LLM_MAX_TOKENS_PER_INCIDENT=0
AIOPS_LLM_INPUT_COST_PER_1K=0
AIOPS_LLM_OUTPUT_COST_PER_1K=0

# Required: production audit/idempotency backend
# DynamoDB table must have string PK, string SK, and TTL enabled on expires_at.
AIOPS_PERSISTENCE_BACKEND=dynamodb
AIOPS_DYNAMODB_TABLE=TODO_DYNAMODB_TABLE_NAME
AIOPS_AUDIT_RETENTION_DAYS=90
AIOPS_IDEMPOTENCY_STALE_SECONDS=120

# Required only if CDO deploys report UI or wants local report JSON retention.
REPORTS_DIR=/var/lib/tf1-ai/reports

# File backend fallback only. Do not set these when using DynamoDB mode.
# AIOPS_PERSISTENCE_BACKEND=file
# AIOPS_AUDIT_LOG_PATH=/var/lib/tf1-ai/audit/audit-log.jsonl
# AIOPS_IDEMPOTENCY_DIR=/var/lib/tf1-ai/audit/idempotency

# Optional: bounded evidence/context integrations.
# Fill whichever evidence path CDO supports.
PROMETHEUS_URL=TODO_BOUNDED_PROMETHEUS_URL
LOKI_URL=TODO_BOUNDED_LOKI_URL
JAEGER_URL=TODO_BOUNDED_JAEGER_URL
DEPLOY_METADATA_PATH=TODO_DEPLOY_METADATA_JSON_PATH
OWNERSHIP_PATH=TODO_OWNERSHIP_RUNBOOK_JSON_PATH
EVIDENCE_BUNDLE_BASE_PATH=TODO_EVIDENCE_BUNDLE_BASE_PATH
JIRA_HISTORY_PATH=TODO_READONLY_JIRA_HISTORY_ACCOUNT_MAP
KNOWN_ERRORS_PATH=TODO_KNOWN_ERRORS_JSON_PATH
AIOPS_CONTEXT_TOOL_TIMEOUT_SECONDS=3
LLM_TOOL_MAX_WINDOW_MINUTES=60
LLM_TOOL_LOG_LIMIT=50
LLM_TOOL_MAX_CALLS=3

# Evidence budget / payload caps
AIOPS_MAX_EVIDENCE_BYTES=262144
AIOPS_MAX_METRIC_SERIES=20
AIOPS_MAX_METRIC_POINTS_PER_SERIES=120
AIOPS_MAX_LOG_RECORDS=50
AIOPS_MAX_TRACE_RECORDS=20
AIOPS_MAX_LOG_MESSAGE_CHARS=500
AIOPS_MAX_TRACE_LABEL_BYTES=2048

# QA / observability
AIOPS_QA_MAX_ITERATIONS=1
AIOPS_QA_REPAIR_MAX_ITERATIONS=1
AIOPS_OBSERVABILITY_ENABLED=true
AIOPS_LOG_POLICY=metadata_only
AIOPS_LOG_LEVEL=INFO
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=

# Optional: worker/demo flow only if CDO runs app.aiops_worker.
TRIAGE_URL=TODO_AI_ENGINE_V1_TRIAGE_URL
REPORT_BASE_URL=TODO_REPORT_UI_BASE_URL
TENANT_ID=TODO_TENANT_ID
SERVICE_NAME=TODO_SERVICE_NAME
ENVIRONMENT=prod
SQS_QUEUE_URL=TODO_INBOUND_INCIDENT_SEED_QUEUE_URL
SQS_WAIT_SECONDS=5
SQS_MAX_MESSAGES=1
SLACK_WEBHOOK_URL=

# Optional: Slack/Jira Triage-Hub notify SQS handoff.
TRIAGE_HUB_NOTIFY_SQS_URL=TODO_CDO_NOTIFY_QUEUE_URL
TRIAGE_HUB_NOTIFY_SQS_DRY_RUN=false
